---
import Layout from "../layouts/Layout.astro";
import "../styles/font-lab.css";

const candidates = [
  { name: "IBM Plex Mono", family: '"IBM Plex Mono", monospace', weight: 700 },
  { name: "JetBrains Mono", family: '"JetBrains Mono", monospace', weight: 700 },
  { name: "SF Mono", family: 'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace', weight: 700 },
];
---

<Layout title="Roder font lab">
  <section class="container">
    <div class="hero">
      <div class="hero-copy">
        <div class="eyebrow-line">Wordmark study</div>
        <h1 class="wordmark">Roder</h1>
        <p class="tagline">
          Monospace wordmark candidates for the Roder brand system.
        </p>
      </div>
      <img class="logo" src="/roder-icon.png" alt="Roder icon" />
    </div>

    <div class="features">
      {candidates.map((c) => (
        <div class="feature-card">
          <h3>{c.name}</h3>
          <p style={`font-family:${c.family};font-weight:${c.weight};font-size:2.4rem;color:var(--graphite);margin-top:0.6rem;`}>
            Roder
          </p>
          <p style={`font-family:${c.family};font-weight:${c.weight};`}>
            Rust-native extensible agent harness
          </p>
        </div>
      ))}
    </div>
  </section>
</Layout>
