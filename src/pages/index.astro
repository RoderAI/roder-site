---
import Layout from "../layouts/Layout.astro";
import "../styles/home.css";
import "../styles/home-foundation.css";
import "../styles/home-sections.css";

const proofPoints = [
  { value: "Rust", label: "typed runtime core" },
  { value: "JSON-RPC", label: "shared app-server control plane" },
  { value: "Replay", label: "events, sessions, and checkpoints" },
  { value: "Extensions", label: "providers, tools, memory, runners" },
];

const runtimeCards = [
  {
    title: "Turn engine",
    body: "Own lifecycle, cancellation, context assembly, provider streaming, and end-of-turn semantics in one stable loop.",
    tone: "orange",
  },
  {
    title: "Tool policy",
    body: "Route shell, filesystem, browser, edit, and domain tools through explicit specs, approvals, scopes, and audit events.",
    tone: "ink",
  },
  {
    title: "State and replay",
    body: "Persist sessions, checkpoints, turn items, and traces so evals, resumes, forks, and training runs use the same record.",
    tone: "mint",
  },
  {
    title: "Extension kernel",
    body: "Replace providers, memory, storage, policy, event sinks, runners, and UI surfaces without taking over the runtime.",
    tone: "silver",
  },
];

const audiences = [
  {
    title: "Agent product teams",
    body: "Ship a differentiated product surface on top of a runtime that already understands tools, state, permissions, and replay.",
  },
  {
    title: "AI labs and eval teams",
    body: "Run repeatable trajectories, compare providers, export structured traces, and plug the harness into RL infrastructure.",
  },
  {
    title: "Platform engineers",
    body: "Embed coding agents behind internal tools, CI jobs, desktop clients, Chrome control, or hosted sandbox workers.",
  },
];

const foundationPillars = [
  ["Community", "extensions, fixes, shared lessons"],
  ["Companies", "product velocity on a common base"],
  ["Startups", "move faster without rebuilding the harness"],
  ["Labs", "repeatable evals and training loops"],
];

const harnessLayers = ["tools", "policy", "providers", "state", "replay"];

const typewriterAudiences = [
  "coding agents",
  "local software",
  "CI runners",
  "desktop apps",
  "mobile apps",
  "games",
  "embedded AI",
  "ML labs",
  "tinkerers",
  "vimmers",
];

const headlineAria = `Harness infrastructure for ${typewriterAudiences
  .slice(0, -1)
  .join(", ")}, and ${typewriterAudiences[typewriterAudiences.length - 1]}.`;
---

<Layout
  title="Roder · runtime infrastructure for coding agents"
  description="Roder is a Rust runtime for teams building, evaluating, and embedding coding agents that need real tools, policy, state, events, and replay."
>
  <div class="home-page">
    <section class="home-hero">
      <div class="home-container home-hero-grid">
        <div class="home-copy reveal">
          <h1 class="home-headline" aria-label={headlineAria}>
            <span class="headline-line">Harness</span>
            <span class="headline-line">infrastructure</span>
            <span class="headline-line headline-line-for">
              <span>for</span>
              <span
                class="typewriter-word"
                data-typewriter-target
                data-phrases={JSON.stringify(typewriterAudiences)}
                aria-hidden="true"
              >
                {typewriterAudiences[0]}
              </span>
              <span class="typewriter-caret" aria-hidden="true"></span>
            </span>
          </h1>
          <p class="home-lede">
            Roder gives serious agent teams the machinery every production harness needs:
            real tools, policy, provider abstraction, durable state, replayable events, and
            one control plane for every client.
          </p>
          <div class="home-actions" aria-label="Primary actions">
            <a class="home-button home-button-primary" href="/docs/">
              <span>Read the docs</span>
              <span class="button-glyph">↗</span>
            </a>
            <a class="home-button home-button-secondary" href="/contact/">
              <span>Talk to the team</span>
              <span class="button-glyph">→</span>
            </a>
          </div>
          <div class="home-proofline" aria-label="Roder positioning">
            <span>Open source</span>
            <span>Provider neutral</span>
            <span>Built for evals and products</span>
          </div>
        </div>

        <div class="hero-visual reveal">
          <div class="visual-shell">
            <div class="visual-core">
              <div class="brand-lockup">
                <div class="brand-mark-tray">
                  <img src="/roder-icon.png" alt="Roder triad hex mark" />
                </div>
                <div>
                  <p class="brand-name">roder</p>
                </div>
              </div>

              <div class="harness-artifact" aria-label="Reusable harness base layers">
                <div class="artifact-slab artifact-slab-top">
                  <span>shared harness surface</span>
                  <strong>one base, many products</strong>
                </div>
                <div class="artifact-layers" aria-hidden="true">
                  {harnessLayers.map((layer, index) => (
                    <span style={`--layer-index: ${index}`}>{layer}</span>
                  ))}
                </div>
                <div class="artifact-slab artifact-slab-base">roder runtime foundation</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="proof-strip reveal" aria-label="Roder product proof points">
      <div class="home-container proof-grid">
        {proofPoints.map((point) => (
          <div>
            <strong>{point.value}</strong>
            <span>{point.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="home-section foundation-story">
      <div class="home-container foundation-story-grid">
        <div class="foundation-copy reveal">
          <p class="section-kicker">Open foundation</p>
          <h2>The shared base for harness engineering.</h2>
          <p>
            Every serious agent project grows the same machinery: tools, policy,
            provider abstraction, durable state, replay, eval traces, and client control.
            Roder makes that base open, reusable, and compounding.
          </p>
        </div>

        <div class="foundation-stage reveal" aria-label="Roder mission: Linux for harness engineering">
          <div class="foundation-stage-head">
            <span>Linux for harness engineering</span>
            <strong>Build once. Compound together.</strong>
          </div>

          <div class="foundation-builders">
            {foundationPillars.map(([title, body], index) => (
              <div class="foundation-builder" style={`--builder-index: ${index}`}>
                <strong>{title}</strong>
                <span>{body}</span>
              </div>
            ))}
          </div>

          <div class="foundation-flow" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>

          <div class="foundation-base">
            <div>
              <span>roder base</span>
              <strong>tools · policy · providers · state · replay</strong>
            </div>
            <img src="/roder-icon.png" alt="" />
          </div>

          <div class="foundation-compounds" aria-label="Roder compounding loop">
            <span>Open interfaces</span>
            <span>Shared extensions</span>
            <span>Reusable eval traces</span>
            <span>Better defaults</span>
          </div>
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="home-container">
        <div class="section-heading reveal">
          <div>
            <div class="home-badge">Runtime architecture</div>
            <h2>One core. Replaceable edges.</h2>
          </div>
          <a class="text-link" href="/docs/architecture/">Explore architecture</a>
        </div>

        <div class="runtime-bento">
          {runtimeCards.map((card) => (
            <article class={`bento-shell reveal tone-${card.tone}`}>
              <div class="bento-core">
                <span class="bento-index"></span>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section">
      <div class="home-container audience-layout">
        <div class="audience-copy reveal">
          <div class="home-badge">Who it is for</div>
          <h2>Built for teams whose agents have to survive contact with real workflows.</h2>
          <p>
            Roder is intentionally lower-level than a polished chat app and higher-level
            than a pile of crates. It is the runtime foundation you build on when the
            agent has to be inspectable, controllable, and repeatable.
          </p>
        </div>
        <div class="audience-list">
          {audiences.map((audience) => (
            <article class="audience-card reveal">
              <h3>{audience.title}</h3>
              <p>{audience.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-section final-cta">
      <div class="home-container">
        <div class="cta-shell reveal">
          <div class="cta-core">
            <div>
              <div class="home-badge">Alpha, useful now</div>
              <h2>Build on the harness instead of rebuilding it.</h2>
              <p>
                Start with the docs, inspect the eval trajectory, or talk to the Roder
                team about embedded harnesses, RL infrastructure, product integrations,
                and OSS sponsorship.
              </p>
            </div>
            <div class="home-actions">
              <a class="home-button home-button-primary" href="/docs/install/">
                <span>Run it locally</span>
                <span class="button-glyph">↗</span>
              </a>
              <a class="home-button home-button-secondary" href="/evals/">
                <span>See evals</span>
                <span class="button-glyph">→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script>
    const typewriterTarget = document.querySelector("[data-typewriter-target]");

    if (typewriterTarget) {
      const phrases = JSON.parse(typewriterTarget.dataset.phrases || "[]");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (prefersReducedMotion || phrases.length < 2) {
        typewriterTarget.textContent = phrases[0] || "";
      } else {
        let phraseIndex = 0;
        let characterIndex = phrases[0].length;
        let isDeleting = true;

        const wait = (duration) => new Promise((resolve) => window.setTimeout(resolve, duration));

        const typeNextFrame = async () => {
          const phrase = phrases[phraseIndex];
          typewriterTarget.textContent = phrase.slice(0, characterIndex);

          if (!isDeleting && characterIndex === phrase.length) {
            await wait(1450);
            isDeleting = true;
          } else if (isDeleting && characterIndex === 0) {
            phraseIndex = (phraseIndex + 1) % phrases.length;
            isDeleting = false;
            await wait(220);
          }

          characterIndex += isDeleting ? -1 : 1;
          window.setTimeout(typeNextFrame, isDeleting ? 28 : 48);
        };

        window.setTimeout(typeNextFrame, 950);
      }
    }

    const revealTargets = document.querySelectorAll(".reveal");
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { rootMargin: "0px 0px -12% 0px", threshold: 0.12 },
    );

    revealTargets.forEach((target) => revealObserver.observe(target));
  </script>
</Layout>
